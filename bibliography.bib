@article{TENCATE,
title = {Modal languages for topology: Expressivity and definability},
journal = {Annals of Pure and Applied Logic},
volume = {159},
number = {1},
pages = {146-170},
year = {2009},
issn = {0168-0072},
doi = {https://doi.org/10.1016/j.apal.2008.11.001},
url = {https://www.sciencedirect.com/science/article/pii/S016800720800184X},
author = {Balder {ten Cate} and David Gabelaia and Dmitry Sustretov},
keywords = {Modal logic, Topology, Expressivity, Definability},
abstract = {In this paper we study the expressive power and definability for (extended) modal languages interpreted on topological spaces. We provide topological analogues of the van Benthem characterization theorem and the Goldblatt–Thomason definability theorem in terms of the well-established first-order topological language Lt.}
}